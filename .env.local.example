# Airtable Configuration
# Get these values from your Airtable account at https://airtable.com/account

# Your Airtable API key
AIRTABLE_API_KEY=your_api_key_here

# Your Airtable Base ID (found in the URL: https://airtable.com/app{BASE_ID})
AIRTABLE_BASE_ID=your_base_id_here

# Your Bridge Projects Table ID
AIRTABLE_TABLE_ID=your_table_id_here
